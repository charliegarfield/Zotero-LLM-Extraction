pref-title = LLM Metadata Extractor Settings

# Provider settings
pref-provider = LLM Provider
pref-api-key = API Key
pref-endpoint = Custom Endpoint
pref-model = Model
pref-temperature = Temperature
pref-max-pages = Max pages to extract

# Verification
pref-verification-title = Verification
pref-verify-doi = Auto-verify DOIs against CrossRef
pref-verify-isbn = Auto-verify ISBNs against Google Books
pref-enable-ocr = Enable OCR fallback for image-only PDFs

# Behavior
pref-behavior-title = Behavior
pref-overwrite-mode = Overwrite existing fields
pref-overwrite-never = Never
pref-overwrite-ask = Ask each time
pref-overwrite-empty = Empty fields only
pref-overwrite-always = Always

# Privacy
pref-privacy-title = Privacy
pref-privacy-notice = This plugin sends document text to the configured LLM API for metadata extraction. API keys are stored in Zotero's preferences file (prefs.js) and are not encrypted at rest. For maximum privacy, configure a local LLM endpoint.
