# LLM Metadata Extractor - Environment Variables
# These are NOT used by the plugin at runtime (it uses Zotero preferences).
# This file documents the API keys you'll need.

# Anthropic API Key (for Claude models)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# OpenAI API Key (for GPT models)
OPENAI_API_KEY=sk-xxxxx

# Custom endpoint for OpenAI-compatible providers (e.g., Ollama)
# CUSTOM_LLM_ENDPOINT=http://localhost:11434/v1/chat/completions
